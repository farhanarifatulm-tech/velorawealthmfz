// BUDGET
// =========================================================
function addBudgetLimit(){
  const cat    = document.getElementById("limitCategory").value.trim();
  const amount = toUSD(Number(document.getElementById("limitAmount").value));
  if(!cat||!amount) return;
  const ex = budgetLimits.findIndex(l=>l.category.toLowerCase()===cat.toLowerCase());
  if(ex>=0) budgetLimits[ex].limit=amount;
  else budgetLimits.push({category:cat,limit:amount});
  document.getElementById("limitCategory").value="";
  document.getElementById("limitAmount").value="";
  scheduleSave(); renderBudget();
}

function renderBudget(){
  const month       = getMonth("budgetMonth");
  const monthIncome = sumBy(filterByMonth(incomeData,month),"amount");
  const monthExp    = sumBy(filterByMonth(expensesData,month),"amount");
  const remaining   = monthIncome - monthExp;
  const rate        = monthIncome>0?((remaining/monthIncome)*100).toFixed(1):0;

  document.getElementById("budgetIncome").textContent    = fmt(monthIncome);
  document.getElementById("budgetExpenses").textContent  = fmt(monthExp);
  document.getElementById("budgetRemaining").textContent = fmt(remaining);
  document.getElementById("budgetSavingsRate").textContent = rate+"%";
  document.getElementById("budgetRemaining").className =
    "stat-value "+(remaining>=0?"income-positive":"expense-negative");

  const ll = document.getElementById("budgetLimitList");
  ll.innerHTML = "";
  if(!budgetLimits.length){ ll.innerHTML=`<p style="margin-bottom:12px">No limits set yet.</p>`; return; }
  budgetLimits.forEach((lim,i)=>{
    const spent = sumBy(filterByMonth(expensesData,month).filter(e=>e.category.toLowerCase().includes(lim.category.toLowerCase())),"amount");
    const pct   = lim.limit>0?Math.min((spent/lim.limit)*100,100):0;
    const over  = spent>lim.limit;
    ll.innerHTML += `
      <div style="margin-bottom:16px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
          <span style="font-weight:600">${lim.category}</span>
          <span>
            <span class="${over?"expense-negative":"income-positive"}">${fmt(spent)}</span>
            <span style="color:var(--sub)"> / ${fmt(lim.limit)}</span>
            <button class="action-btn delete-btn" style="margin-left:8px" onclick="deleteBudgetLimit(${i})">✕</button>
          </span>
        </div>
        <div class="progress-bar"><div class="progress" style="width:${pct}%;background:${over?"#f87171":"linear-gradient(90deg,#8B5CF6,#34D399)"}"></div></div>
        ${over?`<small class="expense-negative">⚠️ Over budget by ${fmt(spent-lim.limit)}</small>`:""}
      </div>`;
  });
}

function deleteBudgetLimit(i){ budgetLimits.splice(i,1); scheduleSave(); renderBudget(); }

// =========================================================
// DASHBOARD
// =========================================================
function renderDashboard(){
  const month     = getMonth("dashMonth");
  const monthInc  = sumBy(filterByMonth(incomeData,month),"amount");
  const monthExp  = sumBy(filterByMonth(expensesData,month),"amount");
  const balance   = monthInc - monthExp;
  const subTotal  = sumBy(subscriptions,"cost");
  const savings   = Math.max(balance,0);

  document.getElementById("heroIncome").textContent   = fmt(monthInc);
  document.getElementById("heroExpenses").textContent = fmt(monthExp);
  document.getElementById("heroBalance").textContent  = fmt(balance);
  document.getElementById("heroSavings").textContent  = fmt(savings);
  document.getElementById("subTotal").textContent     = fmt(subTotal);
  document.getElementById("heroBalance").className =
    "stat-value "+(balance>=0?"income-positive":"expense-negative");

  const savingsRate  = monthInc>0?(savings/monthInc)*100:0;
  const expenseRatio = monthInc>0?(monthExp/monthInc)*100:0;
  let insight = "";

  if(monthInc===0){
    insight = `<div class="insight-card">📥 No income recorded for this month.</div>`;
  } else {
    if(expenseRatio>90)      insight+=`<div class="insight-card">🔴 Expenses are ${expenseRatio.toFixed(0)}% of income — critically high.</div>`;
    else if(expenseRatio>70) insight+=`<div class="insight-card">⚠️ Expenses at ${expenseRatio.toFixed(0)}% of income — above recommended threshold.</div>`;
    else                     insight+=`<div class="insight-card">✅ Expense ratio ${expenseRatio.toFixed(0)}% — healthy range.</div>`;

    if(savingsRate<10)       insight+=`<div class="insight-card">💡 Savings rate ${savingsRate.toFixed(1)}% — aim for at least 20%.</div>`;
    else if(savingsRate>=20) insight+=`<div class="insight-card">🌱 Savings rate ${savingsRate.toFixed(1)}% — solid discipline.</div>`;

    if(subTotal>monthInc*0.1) insight+=`<div class="insight-card">🔁 Subscriptions ${fmt(subTotal)}/mo = ${((subTotal/monthInc)*100).toFixed(1)}% of income.</div>`;
  }
  document.getElementById("dashInsight").innerHTML=`<h3 style="margin-bottom:12px">📈 Monthly Insights</h3>${insight}`;
}

// =========================================================
// GOALS
// =========================================================
function addGoal(){
  const name   = document.getElementById("goalName").value.trim();
  const target = toUSD(Number(document.getElementById("goalTarget").value));
  if(!name||!target) return;
  goals.push({name,target,saved:0});
  document.getElementById("goalName").value="";
  document.getElementById("goalTarget").value="";
  scheduleSave(); renderGoals();
}

function renderGoals(){
  const grid = document.getElementById("goalGrid");
  grid.innerHTML="";
  goals.forEach((goal,i)=>{
    const pct = Math.min((goal.saved/goal.target)*100,100);
    grid.innerHTML+=`
      <div class="glass">
        <h3>${goal.name}</h3>
        <div class="progress-bar"><div class="progress" style="width:${pct}%"></div></div>
        <p>${fmt(goal.saved)} / ${fmt(goal.target)} (${pct.toFixed(1)}%)</p>
        <br>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn btn-sm" onclick="saveMoney(${i})">+ Save</button>
          <button class="action-btn edit-btn" onclick="editGoal(${i})">✎</button>
          <button class="action-btn delete-btn" onclick="deleteGoal(${i})">✕</button>
        </div>
      </div>`;
  });
}

function saveMoney(i){
  const val=prompt("Amount ("+currentCurrency+")");
  if(val){ goals[i].saved+=toUSD(Number(val)); scheduleSave(); renderGoals(); }
}
function editGoal(i){
  const name=prompt("Goal name",goals[i].name);
  const target=prompt("Target ("+currentCurrency+")",toDisplay(goals[i].target).toFixed(2));
  if(name) goals[i].name=name;
  if(target) goals[i].target=toUSD(Number(target));
  scheduleSave(); renderGoals();
}
function deleteGoal(i){ goals.splice(i,1); scheduleSave(); renderGoals(); }

// =========================================================
// SUBSCRIPTIONS
// =========================================================
function addSub(){
  const name=document.getElementById("subName").value.trim();
  const cost=toUSD(Number(document.getElementById("subCost").value));
  if(!name||!cost) return;
  subscriptions.push({name,cost});
  document.getElementById("subName").value="";
  document.getElementById("subCost").value="";
  scheduleSave(); renderSubs();
}

function renderSubs(){
  const grid=document.getElementById("subGrid");
  grid.innerHTML=""; let total=0;
  subscriptions.forEach((sub,i)=>{
    total+=sub.cost;
    grid.innerHTML+=`
      <div class="glass">
        <h3>${sub.name}</h3><br>
        <p class="expense-negative" style="font-size:20px;font-weight:700">${fmt(sub.cost)}<span style="font-size:12px;font-weight:400">/mo</span></p><br>
        <button class="action-btn delete-btn" onclick="deleteSub(${i})">✕ Remove</button>
      </div>`;
  });
  document.getElementById("subTotal").textContent=fmt(total);
}
function deleteSub(i){ subscriptions.splice(i,1); scheduleSave(); renderSubs(); }

// =========================================================
// ANALYTICS
// =========================================================
function renderAnalytics(){
  const month    = getMonth("analyticsMonth");
  const monthExp = filterByMonth(expensesData,month);
  const monthInc = filterByMonth(incomeData,month);

  const expCats={};
  monthExp.forEach(e=>{ expCats[e.category]=(expCats[e.category]||0)+e.amount; });
  if(chartExpenseInst) chartExpenseInst.destroy();
  chartExpenseInst=new Chart(document.getElementById("chartExpense"),{
    type:"doughnut",
    data:{labels:Object.keys(expCats),datasets:[{data:Object.values(expCats).map(v=>toDisplay(v)),
      backgroundColor:["#8B5CF6","#60A5FA","#34D399","#F59E0B","#F87171","#A78BFA","#6EE7B7","#93C5FD"],borderWidth:0}]},
    options:{plugins:{legend:{position:"bottom"},title:{display:true,text:"Expenses by Category"}}}
  });

  const incCats={};
  monthInc.forEach(i=>{ incCats[i.category]=(incCats[i.category]||0)+i.amount; });
  if(chartIncomeInst) chartIncomeInst.destroy();
  chartIncomeInst=new Chart(document.getElementById("chartIncome"),{
    type:"doughnut",
    data:{labels:Object.keys(incCats),datasets:[{data:Object.values(incCats).map(v=>toDisplay(v)),
      backgroundColor:["#34D399","#6EE7B7","#A7F3D0","#059669","#10B981"],borderWidth:0}]},
    options:{plugins:{legend:{position:"bottom"},title:{display:true,text:"Income by Source"}}}
  });

  const months=[],incArr=[],expArr=[];
  for(let i=5;i>=0;i--){
    const d=new Date(); d.setMonth(d.getMonth()-i);
    const m=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
    months.push(m);
    incArr.push(toDisplay(sumBy(filterByMonth(incomeData,m),"amount")));
    expArr.push(toDisplay(sumBy(filterByMonth(expensesData,m),"amount")));
  }
  if(chartMonthlyInst) chartMonthlyInst.destroy();
  chartMonthlyInst=new Chart(document.getElementById("chartMonthly"),{
    type:"bar",
    data:{labels:months,datasets:[
      {label:"Income",data:incArr,backgroundColor:"#34D399"},
      {label:"Expenses",data:expArr,backgroundColor:"#F87171"}
    ]},
    options:{plugins:{legend:{position:"bottom"},title:{display:true,text:"6-Month Overview"}},scales:{y:{beginAtZero:true}}}
  });

  const totalInc=sumBy(monthInc,"amount");
  const totalExp=sumBy(monthExp,"amount");
  const balance=totalInc-totalExp;
  document.getElementById("monthlyReport").innerHTML=`
    <h3 style="margin-bottom:12px">📋 ${month} Summary</h3>
    <p>Income: <strong class="income-positive">${fmt(totalInc)}</strong></p>
    <p>Expenses: <strong class="expense-negative">${fmt(totalExp)}</strong></p>
    <p>Balance: <strong class="${balance>=0?"income-positive":"expense-negative"}">${fmt(balance)}</strong></p>
    <p>Savings Rate: <strong>${totalInc>0?((Math.max(balance,0)/totalInc)*100).toFixed(1):0}%</strong></p>`;
}

// =========================================================
// REFLECTION
// =========================================================
function saveReflection(){
  const date=document.getElementById("reflectionDate").value;
  const text=document.getElementById("reflectionInput").value.trim();
  if(!date||!text) return;
  reflections.push({date,text});
  document.getElementById("reflectionInput").value="";
  scheduleSave(); renderReflections();
}

function renderReflections(){
  const container=document.getElementById("reflectionHistory");
  container.innerHTML="";
  [...reflections].sort((a,b)=>new Date(b.date)-new Date(a.date)).forEach(item=>{
    const ri=reflections.indexOf(item);
    container.innerHTML+=`
      <div class="reflection-item">
        <strong>📅 ${item.date}</strong>
        <p style="margin-top:8px">${item.text}</p>
        <button class="action-btn delete-btn" style="margin-top:10px" onclick="deleteReflection(${ri})">✕ Delete</button>
      </div>`;
  });
}
function deleteReflection(i){ reflections.splice(i,1); scheduleSave(); renderReflections(); }

// =========================================================
// RENDER ALL
// =========================================================
function renderAll(){
  renderDashboard();
  renderIncome();
  renderExpenses();
  renderBudget();
  renderGoals();
  renderSubs();
  renderReflections();
  renderAnalytics();
}

