// STATE
// =========================================================
let currentCurrency = localStorage.getItem("velora_currency") || "USD";
let currentLanguage = localStorage.getItem("velora_language") || "en";
let currentUser = null;
let saveTimeout = null;

const RATES = {USD:1,IDR:15500,JPY:150,KRW:1330,EUR:0.92,SAR:3.75,BRL:5.1,TRY:32,RUB:92,CNY:7.2,INR:83,THB:36};

let incomeData    = [];
let expensesData  = [];
let goals         = [];
let subscriptions = [];
let reflections   = [];
let budgetLimits  = [];

let chartExpenseInst, chartIncomeInst, chartMonthlyInst;

// =========================================================
// UTILS
// =========================================================
function toDisplay(usd){ return usd * RATES[currentCurrency]; }
function toUSD(display){ return display / RATES[currentCurrency]; }
function fmt(usd){
  return new Intl.NumberFormat(undefined,{style:"currency",currency:currentCurrency}).format(toDisplay(usd));
}
function currentMonth(){
  const n = new Date();
  return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,'0')}`;
}
function getMonth(id){ return document.getElementById(id).value || currentMonth(); }
function filterByMonth(arr,m){ return arr.filter(i => i.date && i.date.startsWith(m)); }
function sumBy(arr,key){ return arr.reduce((s,i)=>s+(i[key]||0),0); }

// =========================================================
// SAVING INDICATOR
// =========================================================
function showSaving(){
  const el = document.getElementById("savingIndicator");
  el.classList.add("show");
  setTimeout(()=>el.classList.remove("show"), 2000);
}

// =========================================================
// AUTH
// =========================================================
let authMode = "login";

function switchTab(mode){
  authMode = mode;
  document.querySelectorAll(".auth-tab").forEach((t,i)=>{
    t.classList.toggle("active", (i===0&&mode==="login")||(i===1&&mode==="register"));
  });
  document.getElementById("authBtn").textContent = mode==="login" ? "Login" : "Create Account";
  document.getElementById("authError").style.display = "none";
  document.getElementById("authSuccess").style.display = "none";
}

function showAuthError(msg){
  const el = document.getElementById("authError");
  el.textContent = msg; el.style.display = "block";
}
function showAuthSuccess(msg){
  const el = document.getElementById("authSuccess");
  el.textContent = msg; el.style.display = "block";
}

async function handleAuth(){
  const email    = document.getElementById("authEmail").value.trim();
  const password = document.getElementById("authPassword").value;
  document.getElementById("authError").style.display = "none";
  document.getElementById("authSuccess").style.display = "none";

  if(!email || !password){ showAuthError("Please fill in all fields."); return; }

  const btn = document.getElementById("authBtn");
  btn.textContent = "Please wait..."; btn.disabled = true;

  if(authMode === "login"){
    const {data, error} = await sb.auth.signInWithPassword({email, password});
    if(error){ showAuthError(error.message); btn.textContent="Login"; btn.disabled=false; return; }
    await onLogin(data.user);
  } else {
    const {data, error} = await sb.auth.signUp({email, password});
    if(error){ showAuthError(error.message); btn.textContent="Create Account"; btn.disabled=false; return; }
    showAuthSuccess("Account created! You can now login.");
    switchTab("login");
  }
  btn.disabled = false;
}

async function handleForgotPassword(){
  const email = document.getElementById("authEmail").value.trim();
  if(!email){ showAuthError("Enter your email first."); return; }
  const {error} = await sb.auth.resetPasswordForEmail(email);
  if(error) showAuthError(error.message);
  else showAuthSuccess("Password reset email sent!");
}

async function handleLogout(){
  await sb.auth.signOut();
  currentUser = null;
  incomeData=[]; expensesData=[]; goals=[]; subscriptions=[]; reflections=[]; budgetLimits=[];
  document.getElementById("mainApp").style.display = "none";
  document.getElementById("authScreen").style.display = "flex";
  document.getElementById("authEmail").value = "";
  document.getElementById("authPassword").value = "";
  switchTab("login");
}

async function onLogin(user){
  currentUser = user;
  document.getElementById("userEmail").textContent = user.email;
  document.getElementById("authScreen").style.display = "none";
  document.getElementById("mainApp").style.display = "flex";
  await loadData();
  const m = currentMonth();
  ["dashMonth","incomeMonth","expenseMonth","budgetMonth","analyticsMonth"].forEach(id=>{
    document.getElementById(id).value = m;
  });
  applyLanguage();
  renderAll();
}

// =========================================================
// DATABASE — LOAD & SAVE
// =========================================================
async function loadData(){
  const {data, error} = await sb
    .from("user_data")
    .select("*")
    .eq("user_id", currentUser.id)
    .single();

  if(error || !data){
    // First time user — buat row kosong
    await sb.from("user_data").insert({user_id: currentUser.id});
    return;
  }

  incomeData    = data.income_data        || [];
  expensesData  = data.expenses_data      || [];
  goals         = data.goals_data         || [];
  subscriptions = data.subscriptions_data || [];
  reflections   = data.reflections_data   || [];
  budgetLimits  = data.budget_limits_data || [];
}

async function saveData(){
  showSaving();
  await sb.from("user_data").upsert({
    user_id:              currentUser.id,
    income_data:          incomeData,
    expenses_data:        expensesData,
    goals_data:           goals,
    subscriptions_data:   subscriptions,
    reflections_data:     reflections,
    budget_limits_data:   budgetLimits,
    updated_at:           new Date().toISOString()
  }, {onConflict: "user_id"});
}

// Debounce save — tidak save setiap keystroke
function scheduleSave(){
  clearTimeout(saveTimeout);
  saveTimeout = setTimeout(saveData, 1000);
}

// =========================================================
// NAVIGATION
// =========================================================
function openPage(pageId, btn){
  document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
  document.getElementById(pageId).classList.add("active");
  document.querySelectorAll(".menu-btn").forEach(b=>b.classList.remove("active-nav"));
  if(btn) btn.classList.add("active-nav");
  renderAll();
}

// =========================================================
// DARK MODE
// =========================================================
function toggleDark(){
  document.body.classList.toggle("dark");
  localStorage.setItem("velora_dark", document.body.classList.contains("dark"));
}
if(localStorage.getItem("velora_dark")==="true") document.body.classList.add("dark");

// =========================================================
// LANGUAGE
// =========================================================
function applyLanguage(){
  const T = translations[currentLanguage] || translations.en;
  document.querySelectorAll("[data-t]").forEach(el=>{
    const k = el.getAttribute("data-t");
    if(T[k]) el.textContent = T[k];
  });
  document.body.style.direction = currentLanguage==="ar" ? "rtl" : "ltr";
}

document.getElementById("languageSwitcher").value = currentLanguage;
document.getElementById("languageSwitcher").addEventListener("change", e=>{
  currentLanguage = e.target.value;
  localStorage.setItem("velora_language", currentLanguage);
  applyLanguage();
});

// =========================================================
// CURRENCY
// =========================================================
document.getElementById("currencySwitcher").value = currentCurrency;
document.getElementById("currencySwitcher").addEventListener("change", e=>{
  currentCurrency = e.target.value;
  localStorage.setItem("velora_currency", currentCurrency);
  renderAll();
});

// =========================================================
// INCOME
// =========================================================
function addIncome(){
  const date   = document.getElementById("incomeDate").value;
  const cat    = document.getElementById("incomeCustomCat").value || document.getElementById("incomeCategory").value;
  const amount = toUSD(Number(document.getElementById("incomeAmount").value));
  if(!date||!amount) return;
  incomeData.push({date,category:cat,amount});
  document.getElementById("incomeAmount").value="";
  document.getElementById("incomeCustomCat").value="";
  scheduleSave(); renderAll();
}

function renderIncome(){
  const month    = getMonth("incomeMonth");
  const filtered = filterByMonth(incomeData, month);
  const list     = document.getElementById("incomeList");
  list.innerHTML = "";
  filtered.forEach(item=>{
    const ri = incomeData.indexOf(item);
    list.innerHTML += `<tr>
      <td>${item.date}</td>
      <td><span class="badge badge-green">${item.category}</span></td>
      <td class="income-positive">${fmt(item.amount)}</td>
      <td><button class="action-btn delete-btn" onclick="deleteIncome(${ri})">✕</button></td>
    </tr>`;
  });
}

function deleteIncome(i){ incomeData.splice(i,1); scheduleSave(); renderAll(); }

// =========================================================
// EXPENSES
// =========================================================
function addExpense(){
  const date     = document.getElementById("expenseDate").value;
  const category = document.getElementById("customCategory").value || document.getElementById("expenseCategory").value;
  const amount   = toUSD(Number(document.getElementById("expenseAmount").value));
  const note     = document.getElementById("expenseNote").value;
  if(!date||!amount) return;
  expensesData.push({date,category,amount,note});
  document.getElementById("expenseAmount").value="";
  document.getElementById("expenseNote").value="";
  document.getElementById("customCategory").value="";
  scheduleSave(); renderAll();
}

function renderExpenses(){
  const month    = getMonth("expenseMonth");
  const filtered = filterByMonth(expensesData, month);
  const list     = document.getElementById("expenseList");
  list.innerHTML = "";
  filtered.forEach(item=>{
    const ri = expensesData.indexOf(item);
    list.innerHTML += `<tr>
      <td>${item.date}</td>
      <td><span class="badge badge-purple">${item.category}</span>${item.note?`<br><small style="color:var(--sub)">${item.note}</small>`:""}</td>
      <td class="expense-negative">${fmt(item.amount)}</td>
      <td>
        <button class="action-btn edit-btn" onclick="editExpense(${ri})">✎</button>
        <button class="action-btn delete-btn" onclick="deleteExpense(${ri})">✕</button>
      </td>
    </tr>`;
  });
}

function editExpense(i){
  const val = prompt("Edit amount ("+currentCurrency+")", toDisplay(expensesData[i].amount).toFixed(2));
  if(val!==null){ expensesData[i].amount=toUSD(Number(val)); scheduleSave(); renderAll(); }
}
function deleteExpense(i){ expensesData.splice(i,1); scheduleSave(); renderAll(); }

