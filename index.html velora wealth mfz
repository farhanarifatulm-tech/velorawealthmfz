<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>VELORA WEALTH™</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#8B5CF6">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.0/dist/umd/supabase.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --purple:#8B5CF6;--mint:#34D399;--blue:#60A5FA;
  --card:rgba(255,255,255,0.75);--text:#111827;--sub:#6b7280;--input-bg:#f1f5f9;
}
body{
  font-family:'Inter',sans-serif;
  background:linear-gradient(135deg,#eef2ff,#fdf2f8,#ecfeff);
  min-height:100vh;color:var(--text);overflow-x:hidden;transition:0.4s;
}
body.dark{
  background:linear-gradient(135deg,#0f172a,#111827,#1e293b);
  --card:rgba(30,41,59,0.72);--text:#f3f4f6;--sub:#cbd5e1;--input-bg:#1e293b;
}

/* AUTH SCREEN */
.auth-screen{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,#eef2ff,#fdf2f8,#ecfeff);
}
body.dark .auth-screen{background:linear-gradient(135deg,#0f172a,#111827,#1e293b);}
.auth-box{
  background:rgba(255,255,255,0.85);backdrop-filter:blur(20px);
  padding:40px;border-radius:28px;width:100%;max-width:420px;
  box-shadow:0 20px 60px rgba(0,0,0,0.1);border:1px solid rgba(255,255,255,0.3);
}
body.dark .auth-box{background:rgba(30,41,59,0.9);}
.auth-logo{
  font-family:'Sora',sans-serif;font-size:32px;font-weight:800;
  background:linear-gradient(90deg,#8B5CF6,#60A5FA,#34D399);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  margin-bottom:8px;
}
.auth-sub{color:var(--sub);font-size:14px;margin-bottom:28px;}
.auth-tabs{display:flex;gap:8px;margin-bottom:24px;}
.auth-tab{
  flex:1;padding:10px;border:none;border-radius:12px;font-weight:600;
  font-size:14px;cursor:pointer;background:var(--input-bg);color:var(--sub);transition:0.2s;
}
.auth-tab.active{background:var(--purple);color:white;}
.auth-error{
  background:#fee2e2;color:#dc2626;padding:12px 16px;
  border-radius:12px;font-size:13px;margin-bottom:12px;display:none;
}
.auth-success{
  background:#d1fae5;color:#059669;padding:12px 16px;
  border-radius:12px;font-size:13px;margin-bottom:12px;display:none;
}

/* APP */
.app{display:flex;min-height:100vh;}
.sidebar{
  width:260px;position:fixed;top:0;left:0;bottom:0;
  padding:28px 20px;background:rgba(255,255,255,0.72);
  backdrop-filter:blur(18px);border-right:1px solid rgba(255,255,255,0.2);
  overflow-y:auto;z-index:999;display:flex;flex-direction:column;gap:4px;
}
body.dark .sidebar{background:rgba(15,23,42,0.92);}
.content{margin-left:260px;width:100%;padding:36px;}
.logo{
  font-family:'Sora',sans-serif;font-size:28px;font-weight:800;
  background:linear-gradient(90deg,#8B5CF6,#60A5FA,#34D399);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  margin-bottom:24px;
}
.user-info{
  padding:12px 16px;border-radius:14px;background:var(--input-bg);
  font-size:12px;color:var(--sub);margin-bottom:8px;word-break:break-all;
}
.menu-btn{
  width:100%;padding:13px 16px;border:none;border-radius:14px;
  background:transparent;cursor:pointer;font-size:14px;font-weight:600;
  text-align:left;transition:0.25s;color:var(--text);
}
.menu-btn:hover,.menu-btn.active-nav{background:#ede9fe;transform:translateX(4px);}
body.dark .menu-btn:hover,body.dark .menu-btn.active-nav{background:#312e81;}
.page{display:none;animation:fade 0.35s ease;}
.page.active{display:block;}
@keyframes fade{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.glass{
  background:var(--card);backdrop-filter:blur(16px);padding:24px;
  border-radius:24px;box-shadow:0 8px 24px rgba(0,0,0,0.07);
  border:1px solid rgba(255,255,255,0.25);margin-bottom:20px;
}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
h1{font-size:40px;margin-bottom:16px;font-family:'Sora',sans-serif;}
h2{font-size:22px;margin-bottom:14px;font-family:'Sora',sans-serif;}
h3{font-size:16px;font-weight:700;margin-bottom:6px;}
p{line-height:1.7;color:var(--sub);font-size:14px;}
.stat-value{font-size:32px;font-weight:800;font-family:'Sora',sans-serif;margin-top:8px;}
.stat-label{font-size:12px;color:var(--sub);font-weight:500;text-transform:uppercase;letter-spacing:0.5px;}
input,select,textarea{
  width:100%;padding:13px 16px;border:none;outline:none;border-radius:14px;
  font-size:14px;margin-bottom:12px;font-family:'Inter',sans-serif;
  background:var(--input-bg);color:var(--text);transition:0.2s;
}
input:focus,select:focus,textarea:focus{box-shadow:0 0 0 3px rgba(139,92,246,0.2);}
label{font-size:13px;font-weight:600;color:var(--sub);display:block;margin-bottom:6px;}
.btn{
  padding:13px 20px;border:none;border-radius:14px;
  background:linear-gradient(90deg,var(--purple),var(--blue));
  color:white;font-weight:700;cursor:pointer;transition:0.25s;font-size:14px;
}
.btn:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(139,92,246,0.35);}
.btn-sm{padding:8px 14px;font-size:13px;border-radius:10px;}
.btn-danger{background:linear-gradient(90deg,#f87171,#ef4444);}
table{width:100%;border-collapse:collapse;}
th{padding:12px 16px;text-align:left;font-size:12px;color:var(--sub);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;}
td{padding:13px 16px;font-size:14px;border-top:1px solid rgba(0,0,0,0.05);}
body.dark td{border-top:1px solid rgba(255,255,255,0.05);}
.badge{display:inline-block;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600;}
.badge-purple{background:#ede9fe;color:#7c3aed;}
.badge-green{background:#d1fae5;color:#059669;}
.action-btn{padding:7px 12px;border:none;border-radius:10px;cursor:pointer;font-weight:700;font-size:12px;margin-right:4px;}
.edit-btn{background:#dbeafe;color:#2563eb;}
.delete-btn{background:#fee2e2;color:#dc2626;}
.progress-bar{width:100%;height:12px;background:#e5e7eb;border-radius:999px;overflow:hidden;margin:12px 0;}
body.dark .progress-bar{background:#374151;}
.progress{height:100%;background:linear-gradient(90deg,#8B5CF6,#34D399);border-radius:999px;transition:width 0.4s;}
.reflection-item{padding:18px;border-radius:18px;background:rgba(255,255,255,0.55);margin-bottom:14px;}
body.dark .reflection-item{background:#1e293b;}
.month-filter{display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap;}
.month-filter input[type=month]{width:auto;margin-bottom:0;}
.insight-card{border-left:4px solid var(--purple);padding:16px 20px;border-radius:0 16px 16px 0;background:var(--input-bg);margin-bottom:12px;font-size:14px;}
.income-positive{color:#059669;font-weight:700;}
.expense-negative{color:#dc2626;font-weight:700;}
.divider{height:1px;background:rgba(0,0,0,0.07);margin:16px 0;}
body.dark .divider{background:rgba(255,255,255,0.07);}
.dark-toggle{margin-top:auto;padding-top:20px;}
.saving-indicator{
  position:fixed;bottom:20px;right:20px;background:#8B5CF6;color:white;
  padding:10px 18px;border-radius:999px;font-size:13px;font-weight:600;
  opacity:0;transition:0.3s;pointer-events:none;z-index:9999;
}
.saving-indicator.show{opacity:1;}
@media(max-width:900px){
  .sidebar{width:100%;height:auto;position:relative;flex-direction:row;overflow-x:auto;padding:16px;gap:6px;}
  .content{margin-left:0;padding:16px;}
  .app{flex-direction:column;}
  .menu-btn{min-width:120px;font-size:13px;}
  h1{font-size:28px;}
  .grid-2{grid-template-columns:1fr;}
  .logo{margin-bottom:0;font-size:22px;}
  .dark-toggle{margin-top:0;padding-top:0;}
}
</style>
</head>
<body>

<!-- SAVING INDICATOR -->
<div class="saving-indicator" id="savingIndicator">☁️ Saving...</div>

<!-- AUTH SCREEN -->
<div id="authScreen" class="auth-screen">
  <div class="auth-box">
    <div class="auth-logo">VELORA™</div>
    <div class="auth-sub">Your personal wealth tracker</div>
    <div class="auth-tabs">
      <button class="auth-tab active" onclick="switchTab('login')">Login</button>
      <button class="auth-tab" onclick="switchTab('register')">Register</button>
    </div>
    <div class="auth-error" id="authError"></div>
    <div class="auth-success" id="authSuccess"></div>
    <input type="email" id="authEmail" placeholder="Email">
    <input type="password" id="authPassword" placeholder="Password">
    <button class="btn" style="width:100%" id="authBtn" onclick="handleAuth()">Login</button>
    <div style="text-align:center;margin-top:16px">
      <button onclick="handleForgotPassword()" style="background:none;border:none;color:var(--purple);cursor:pointer;font-size:13px">Forgot password?</button>
    </div>
  </div>
</div>

<!-- MAIN APP -->
<div id="mainApp" class="app" style="display:none">
<aside class="sidebar">
  <div class="logo">VELORA™</div>
  <div class="user-info" id="userEmail">-</div>
  <button class="menu-btn" onclick="openPage('dashboardPage',this)">🏠 <span data-t="dashboard">Dashboard</span></button>
  <button class="menu-btn" onclick="openPage('incomePage',this)">💰 <span data-t="income">Income</span></button>
  <button class="menu-btn" onclick="openPage('budgetPage',this)">💸 <span data-t="budget">Budget</span></button>
  <button class="menu-btn" onclick="openPage('expensePage',this)">🧾 <span data-t="expenses">Expenses</span></button>
  <button class="menu-btn" onclick="openPage('goalPage',this)">🎯 <span data-t="goals">Goals</span></button>
  <button class="menu-btn" onclick="openPage('subscriptionPage',this)">🔁 <span data-t="subscription">Subscription</span></button>
  <button class="menu-btn" onclick="openPage('analyticsPage',this)">📊 <span data-t="analytics">Analytics</span></button>
  <button class="menu-btn" onclick="openPage('reflectionPage',this)">🧠 <span data-t="reflection">Reflection</span></button>
  <button class="menu-btn" onclick="openPage('settingsPage',this)">⚙️ <span data-t="settings">Settings</span></button>
  <div class="dark-toggle">
    <button class="btn" style="width:100%;margin-bottom:8px" onclick="toggleDark()">🌙 Dark Mode</button>
    <button class="btn btn-danger" style="width:100%" onclick="handleLogout()">🚪 Logout</button>
  </div>
</aside>

<main class="content">

  <!-- DASHBOARD -->
  <section id="dashboardPage" class="page active">
    <h1>VELORA Dashboard</h1>
    <div class="month-filter">
      <label style="margin:0;white-space:nowrap">📅 <span data-t="viewingMonth">Viewing Month:</span></label>
      <input type="month" id="dashMonth" onchange="renderAll()">
    </div>
    <div class="grid">
      <div class="glass"><div class="stat-label" data-t="totalIncome">Total Income</div><div class="stat-value income-positive" id="heroIncome">$0</div></div>
      <div class="glass"><div class="stat-label" data-t="totalExpenses">Total Expenses</div><div class="stat-value expense-negative" id="heroExpenses">$0</div></div>
      <div class="glass"><div class="stat-label" data-t="balance">Balance</div><div class="stat-value" id="heroBalance">$0</div></div>
      <div class="glass"><div class="stat-label" data-t="savings">Savings</div><div class="stat-value" id="heroSavings">$0</div></div>
      <div class="glass"><div class="stat-label" data-t="subscriptions">Subscriptions / mo</div><div class="stat-value" id="subTotal">$0</div></div>
    </div>
    <div class="glass" id="dashInsight"></div>
  </section>

  <!-- INCOME -->
  <section id="incomePage" class="page">
    <h1 data-t="incomeTracker">Income Tracker</h1>
    <div class="grid-2">
      <div class="glass">
        <label data-t="date">Date</label>
        <input type="date" id="incomeDate">
        <label data-t="source">Source / Category</label>
        <select id="incomeCategory">
          <option>💼 Salary</option><option>🔧 Freelance</option>
          <option>📦 Business</option><option>📈 Investment</option>
          <option>🎁 Gift / Other</option>
        </select>
        <input type="text" id="incomeCustomCat" placeholder="Custom source (optional)">
        <label data-t="amount">Amount</label>
        <input type="number" id="incomeAmount" placeholder="0">
        <button class="btn" onclick="addIncome()" data-t="addIncome">+ Add Income</button>
      </div>
      <div class="glass">
        <h3 data-t="incomeHistory">Income History</h3>
        <div class="month-filter"><input type="month" id="incomeMonth" onchange="renderIncome()"></div>
        <table><thead><tr>
          <th data-t="date">Date</th><th data-t="source">Source</th><th data-t="amount">Amount</th><th></th>
        </tr></thead><tbody id="incomeList"></tbody></table>
      </div>
    </div>
  </section>

  <!-- BUDGET -->
  <section id="budgetPage" class="page">
    <h1 data-t="budget">Budget Planner</h1>
    <div class="month-filter">
      <label style="margin:0" data-t="month">Month:</label>
      <input type="month" id="budgetMonth" onchange="renderBudget()">
    </div>
    <div class="grid">
      <div class="glass"><div class="stat-label" data-t="monthlyIncome">Monthly Income</div><div class="stat-value income-positive" id="budgetIncome">$0</div></div>
      <div class="glass"><div class="stat-label" data-t="monthlyExpenses">Monthly Expenses</div><div class="stat-value expense-negative" id="budgetExpenses">$0</div></div>
      <div class="glass"><div class="stat-label" data-t="remaining">Remaining</div><div class="stat-value" id="budgetRemaining">$0</div></div>
      <div class="glass"><div class="stat-label" data-t="savingsRate">Savings Rate</div><div class="stat-value" id="budgetSavingsRate">0%</div></div>
    </div>
    <div class="glass">
      <h3 data-t="setBudgetLimit">Set Budget Limits per Category</h3>
      <div id="budgetLimitList"></div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;">
        <input type="text" id="limitCategory" placeholder="Category name" style="flex:1;margin-bottom:0;">
        <input type="number" id="limitAmount" placeholder="Limit amount" style="flex:1;margin-bottom:0;">
        <button class="btn btn-sm" onclick="addBudgetLimit()" data-t="addLimit">+ Add Limit</button>
      </div>
    </div>
  </section>

  <!-- EXPENSES -->
  <section id="expensePage" class="page">
    <h1 data-t="expenseTracker">Expense Tracker</h1>
    <div class="grid-2">
      <div class="glass">
        <label data-t="date">Date</label>
        <input type="date" id="expenseDate">
        <label data-t="category">Category</label>
        <select id="expenseCategory">
          <option>🍜 Food</option><option>🚗 Transport</option>
          <option>🛍 Shopping</option><option>🎮 Entertainment</option>
          <option>💡 Bills</option><option>🏠 Rent</option>
          <option>💊 Health</option><option>📚 Education</option>
        </select>
        <input type="text" id="customCategory" placeholder="Custom category (optional)">
        <label data-t="amount">Amount</label>
        <input type="number" id="expenseAmount" placeholder="0">
        <input type="text" id="expenseNote" placeholder="Note (optional)">
        <button class="btn" onclick="addExpense()" data-t="addExpense">+ Add Expense</button>
      </div>
      <div class="glass">
        <h3 data-t="expenseHistory">Expense History</h3>
        <div class="month-filter"><input type="month" id="expenseMonth" onchange="renderExpenses()"></div>
        <table><thead><tr>
          <th data-t="date">Date</th><th data-t="category">Category</th><th data-t="amount">Amount</th><th></th>
        </tr></thead><tbody id="expenseList"></tbody></table>
      </div>
    </div>
  </section>

  <!-- GOALS -->
  <section id="goalPage" class="page">
    <h1 data-t="savingGoals">Savings Goals</h1>
    <div class="glass">
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <input type="text" id="goalName" placeholder="Goal name" style="flex:1;margin-bottom:0;">
        <input type="number" id="goalTarget" placeholder="Target amount" style="flex:1;margin-bottom:0;">
        <button class="btn btn-sm" onclick="addGoal()" data-t="addGoal">+ Add Goal</button>
      </div>
    </div>
    <div class="grid" id="goalGrid"></div>
  </section>

  <!-- SUBSCRIPTIONS -->
  <section id="subscriptionPage" class="page">
    <h1 data-t="subscriptions">Subscriptions</h1>
    <div class="glass">
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <input type="text" id="subName" placeholder="Netflix" style="flex:1;margin-bottom:0;">
        <input type="number" id="subCost" placeholder="Monthly cost" style="flex:1;margin-bottom:0;">
        <button class="btn btn-sm" onclick="addSub()" data-t="addSubscription">+ Add</button>
      </div>
    </div>
    <div class="grid" id="subGrid"></div>
  </section>

  <!-- ANALYTICS -->
  <section id="analyticsPage" class="page">
    <h1 data-t="analytics">Analytics</h1>
    <div class="month-filter"><input type="month" id="analyticsMonth" onchange="renderAnalytics()"></div>
    <div class="grid-2">
      <div class="glass"><canvas id="chartExpense"></canvas></div>
      <div class="glass"><canvas id="chartIncome"></canvas></div>
    </div>
    <div class="glass"><canvas id="chartMonthly"></canvas></div>
    <div class="glass" id="monthlyReport"></div>
  </section>

  <!-- REFLECTION -->
  <section id="reflectionPage" class="page">
    <h1 data-t="reflection">Reflection Journal</h1>
    <div class="grid-2">
      <div class="glass">
        <label data-t="date">Date</label>
        <input type="date" id="reflectionDate">
        <label data-t="writeReflection">Write your reflection</label>
        <textarea id="reflectionInput" rows="8" placeholder="How was your financial discipline this month?"></textarea>
        <button class="btn" onclick="saveReflection()" data-t="save">Save Reflection</button>
      </div>
      <div class="glass">
        <h3 data-t="history">History</h3>
        <div id="reflectionHistory"></div>
      </div>
    </div>
  </section>

  <!-- SETTINGS -->
  <section id="settingsPage" class="page">
    <h1 data-t="settings">Settings</h1>
    <div class="glass">
      <label data-t="currency">Currency</label>
      <select id="currencySwitcher">
        <option value="USD">🇺🇸 USD</option><option value="IDR">🇮🇩 IDR</option>
        <option value="JPY">🇯🇵 JPY</option><option value="KRW">🇰🇷 KRW</option>
        <option value="EUR">🇪🇺 EUR</option><option value="SAR">🇸🇦 SAR</option>
        <option value="BRL">🇧🇷 BRL</option><option value="TRY">🇹🇷 TRY</option>
        <option value="RUB">🇷🇺 RUB</option><option value="CNY">🇨🇳 CNY</option>
        <option value="INR">🇮🇳 INR</option><option value="THB">🇹🇭 THB</option>
      </select>
      <div class="divider"></div>
      <label data-t="language">Language</label>
      <select id="languageSwitcher">
        <option value="en">English</option><option value="id">Indonesia</option>
        <option value="jp">日本語</option><option value="kr">한국어</option>
        <option value="fr">Français</option><option value="ar">العربية</option>
        <option value="pt">Português</option><option value="tr">Türkçe</option>
        <option value="ru">Русский</option><option value="zh">中文</option>
        <option value="hi">हिन्दी</option><option value="th">ไทย</option>
      </select>
    </div>
  </section>

</main>
</div>

